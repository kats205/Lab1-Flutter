# ==============================================================================
# Gitignore for Jobspot Flutter Application (Lab 1)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. OS & System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Icon?

# ------------------------------------------------------------------------------
# 2. IDE & Text Editors
# ------------------------------------------------------------------------------
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/
.gradle/
cmake-build-*/

# Visual Studio Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# Other Editors
*~
*.swp
*.bak
.history

# ------------------------------------------------------------------------------
# 3. Python (Scripts & Environments)
# ------------------------------------------------------------------------------
# Python cache files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# ------------------------------------------------------------------------------
# 4. Flutter & Dart Core
# ------------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-preload-cache/
.pub-cache/
.pub/
build/
coverage/

# Symbols and source maps
app.*.symbols
app.*.map.json
flutter_*.png

# ------------------------------------------------------------------------------
# 5. Android Platform
# ------------------------------------------------------------------------------
**/android/**/gradle-wrapper.jar
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java

# Keystores & Credentials
**/android/key.properties
*.jks
*.keystore
*.ap_
*.apk
*.aab

# Build artifacts
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# ------------------------------------------------------------------------------
# 6. iOS Platform
# ------------------------------------------------------------------------------
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata/
**/ios/.generated/
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# ------------------------------------------------------------------------------
# 7. Desktop Platforms (macOS, Windows, Linux)
# ------------------------------------------------------------------------------
# macOS Desktop
**/macos/Flutter/ephemeral/
**/macos/Flutter/GeneratedPluginRegistrant.swift

# Windows Desktop
**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake
**/windows/flutter/ephemeral/

# Linux Desktop
**/linux/flutter/generated_plugin_registrant.cc
**/linux/flutter/generated_plugin_registrant.h
**/linux/flutter/generated_plugins.cmake
**/linux/flutter/ephemeral/

# ------------------------------------------------------------------------------
# 8. Figma & Temporary Development Dumps
# ------------------------------------------------------------------------------
# Large JSON/Text files extracted from Figma (uncomment if you want to ignore)
# **/figma_data.json
# **/figma_details_dump.txt

# ------------------------------------------------------------------------------
# 9. AI & Developer Agents
# ------------------------------------------------------------------------------
AGENT.md
.agent/